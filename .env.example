NODE_ENV=development
APP_NAME=PulseBoard
PORT=3000
API_PREFIX=api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulseboard?schema=public
DB_POOL_SIZE=10
DB_SSL=false

# Generates 32-character secret keys (uncomment or edit for production)
JWT_ACCESS_SECRET=abcdefghijklmnopqrstuvwxyz123456
JWT_REFRESH_SECRET=abcdefghijklmnopqrstuvwxyz12345678
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
